# Server
PORT=8002
ENV=development
LOG_LEVEL=INFO

# ── Rules ──────────────────────────────────────────────────────────────
# Client confirmed: UAE. Point at rules_uae.json.
# To switch standard later, change this path and call POST /rules/reload.
RULES_CONFIG_PATH=config/rules_uae.json

# CORS — Member 3's Node.js core API origin
ALLOWED_ORIGIN=http://localhost:3000

# False-detection validator thresholds (app/core/validator.py)
MIN_VALID_AREA_SQFT=10
MAX_AREA_OVERSHOOT_RATIO=2.0
MIN_CONFIDENCE=0.5
