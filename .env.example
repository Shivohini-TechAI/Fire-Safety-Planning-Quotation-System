# CORS — Member 3's Node.js core API origin
ALLOWED_ORIGIN=http://localhost:3000

# Shared secret Member 3/4's backend must send as the X-API-Key header
# when calling POST /recommend or POST /rules/reload. Leave blank to
# disable auth for solo local dev — but ALWAYS set a real value before
# exposing this server via ngrok or deploying it anywhere reachable.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
RULE_ENGINE_API_KEY=

# False-detection validator thresholds (app/core/validator.py)
MIN_VALID_AREA_SQFT=10
